{
  "title": "Pharma MLOps — Model Serving",
  "uid": "pharma-serving",
  "schemaVersion": 38,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Prediction Rate (req/min)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(pharma_predictions_total[1m]) * 60",
          "legendFormat": "predictions/min",
          "datasource": "Prometheus"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2,
      "title": "Latency p99 (seconds)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(pharma_prediction_latency_seconds_bucket[5m]))",
          "legendFormat": "p99",
          "datasource": "Prometheus"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 3,
      "title": "Effective vs Ineffective Predictions",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "pharma_predictions_total",
          "legendFormat": "class={{prediction_class}} conf={{confidence}}",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 4,
      "title": "Prediction Latency Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(pharma_prediction_latency_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "datasource": "Prometheus"
        },
        {
          "expr": "histogram_quantile(0.95, rate(pharma_prediction_latency_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "datasource": "Prometheus"
        },
        {
          "expr": "histogram_quantile(0.99, rate(pharma_prediction_latency_seconds_bucket[5m]))",
          "legendFormat": "p99",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 5,
      "title": "Serving API Up",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 4 },
      "targets": [
        {
          "expr": "up{job='serving-api'}",
          "legendFormat": "status",
          "datasource": "Prometheus"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "color": "red", "value": 0 },
            { "color": "green", "value": 1 }
          ]
        }
      }
    }
  ]
}
